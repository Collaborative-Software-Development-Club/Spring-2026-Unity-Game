  npcName: Marty
  voiceSound: {fileID: 0}
  voicePitch: 1
  dialogueLines:
  - Yo, first visitor in a while and it's a freaking WIZARD!
  - I'm Marty!
  - That's right. THE Marty, of marty.com.
  - Mi server is tu server my friend, so have a look around!
  - Of course, if you wanna surf the web to go elsewhere,
  - you can go over to that blue pedestal over there and type a new URL!
  - Doesn't have a ton of keys though...
  - You have a few decent characters to start with, though- you can just delete them
    if you wanna rearrange em! But...
  - You may need to find some new ones along the way!
  autoProgressLines: 
  autoProgressDelay: 1.5
  typingSpeed: 0.05
